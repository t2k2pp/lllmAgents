{
  "name": "localllm-agent",
  "version": "0.1.0",
  "description": "CLI-based AI agent powered by local LLMs (Ollama, LM Studio, llama.cpp, vLLM)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "localllm": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "setup": "tsx src/index.ts --setup",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "chalk": "^5.4.1",
    "glob": "^11.0.1",
    "inquirer": "^12.3.2",
    "marked": "^15.0.6",
    "marked-terminal": "^7.3.0",
    "ora": "^8.1.1",
    "playwright": "^1.50.1",
    "undici": "^7.3.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.13.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
